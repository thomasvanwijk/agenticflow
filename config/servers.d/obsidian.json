{
    "name": "obsidian",
    "transport": "stdio",
    "description": "Agenticflow — core Obsidian memory and note-taking tools",
    "command": "node",
    "args": [
        "/app/agenticflow-memory-mcp/dist/index.js"
    ],
    "env": {
        "AGENTICFLOW_ROLE": "memory",
        "VAULT_PATH": "/vault",
        "CHROMA_HOST": "chroma",
        "CHROMA_PORT": "8000",
        "OLLAMA_BASE_URL": "http://host.docker.internal:11434",
        "ai_attribution_enabled": "true",
        "ai_attribution_include_model": "true",
        "ai_attribution_include_date": "true"
    },
    "session_mode": "stateful"
}
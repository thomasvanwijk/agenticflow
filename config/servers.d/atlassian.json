{
    "name": "atlassian",
    "transport": "stdio",
    "description": "Atlassian Jira MCP server",
    "command": "npx",
    "args": [
        "-y",
        "@mcpio/jira"
    ],
    "env": {
        "JIRA_HOST": "${MCP_ATLASSIAN_BASE_URL}",
        "JIRA_BASE_URL": "${MCP_ATLASSIAN_BASE_URL}",
        "JIRA_EMAIL": "${MCP_ATLASSIAN_EMAIL}",
        "JIRA_API_TOKEN": "${MCP_ATLASSIAN_API_TOKEN}"
    },
    "session_mode": "stateful"
}
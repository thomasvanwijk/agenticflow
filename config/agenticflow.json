{
    "name": "agenticflow",
    "transport": "stdio",
    "description": "Agenticflow — semantic memory, tool discovery and execution for your Obsidian vault and integrations",
    "command": "node",
    "args": [
        "/app/agenticflow-memory-mcp/dist/index.js"
    ],
    "env": {
        "VAULT_PATH": "/vault",
        "CHROMA_HOST": "chroma",
        "CHROMA_PORT": "8000",
        "OLLAMA_BASE_URL": "http://host.docker.internal:11434",
        "EMBEDDING_PROVIDER": "local",
        "EMBEDDING_MODEL": "Xenova/all-MiniLM-L6-v2"
    },
    "session_mode": "stateful"
}
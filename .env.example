# .env file for docker-compose
# Copy this to .env and fill in your values.
# .env is gitignored.

# Gateway port (default: 18080)
HOST_PORT=18080

# Your Obsidian vault path (any vault structure works)
VAULT_PATH=/Users/YOURNAME/Documents/Obsidian/YourVault

# Postgres password (used internally, change for security)
POSTGRES_PASSWORD=changeme

# Embedding provider: "ollama" or "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# If using ollama on a non-default port:
# OLLAMA_BASE_URL=http://localhost:11434

# If using openai embeddings instead:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# AI Attribution (Authorship)
AI_ATTRIBUTION_ENABLED=false
AI_ATTRIBUTION_CALLOUT_TYPE=ai
AI_ATTRIBUTION_INCLUDE_MODEL=true
AI_ATTRIBUTION_INCLUDE_DATE=true
